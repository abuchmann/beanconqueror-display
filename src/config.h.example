// Deep sleep interval (microseconds) — 5 minutes default
#define SLEEP_INTERVAL_US (5 * 60 * 1000000ULL)

// E-Paper display pins (ESP32 VSPI)
#define EPD_BUSY 4
#define EPD_RST  16
#define EPD_DC   17
#define EPD_CS   5
// CLK = 18 (SCK), DIN = 23 (MOSI) — hardware SPI defaults
